{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CodeDeployRevisionFromS3",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:GetObjectVersion"],
      "Resource": "arn:aws:s3:::fighting-game-assets-508768431157/deploy/*"
    },
    {
      "Sid": "CodeDeployRevisionListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::fighting-game-assets-508768431157",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["deploy/*"]
        }
      }
    },
    {
      "Sid": "FinishActiveMatches",
      "Effect": "Allow",
      "Action": ["dynamodb:UpdateItem", "dynamodb:GetItem"],
      "Resource": "arn:aws:dynamodb:ap-southeast-1:508768431157:table/ActiveMatches"
    }
  ]
}
