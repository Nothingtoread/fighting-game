{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CodeDeployLambdaMatchMaker",
      "Effect": "Allow",
      "Action": [
        "codedeploy:CreateDeployment",
        "codedeploy:GetDeployment",
        "codedeploy:GetDeploymentConfig",
        "codedeploy:RegisterApplicationRevision",
        "codedeploy:ListDeployments"
      ],
      "Resource": [
        "arn:aws:codedeploy:ap-southeast-1:508768431157:application:FightingGameMatchmakerDeploy",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentgroup:FightingGameMatchmakerDeploy/FightingGameMatchmaker-live",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaAllAtOnce",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaLinear10PercentEvery1Minute",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaLinear10PercentEvery2Minutes",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaLinear10PercentEvery3Minutes",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaCanary10Percent5Minutes",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaCanary10Percent10Minutes",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaCanary10Percent15Minutes",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.LambdaCanary10Percent30Minutes"
      ]
    },
    {
      "Sid": "CodeDeployEC2GameServer",
      "Effect": "Allow",
      "Action": [
        "codedeploy:CreateDeployment",
        "codedeploy:GetDeployment",
        "codedeploy:GetDeploymentConfig",
        "codedeploy:RegisterApplicationRevision",
        "codedeploy:ListDeployments"
      ],
      "Resource": [
        "arn:aws:codedeploy:ap-southeast-1:508768431157:application:FightingGameServerDeploy",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentgroup:FightingGameServerDeploy/FightingGameServer-fleet",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.OneAtATime",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.HalfAtATime",
        "arn:aws:codedeploy:ap-southeast-1:508768431157:deploymentconfig:CodeDeployDefault.AllAtOnce"
      ]
    },
    {
      "Sid": "LambdaPublishAndAliasForCodeDeploy",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:GetFunction",
        "lambda:PublishVersion",
        "lambda:GetAlias",
        "lambda:UpdateAlias"
      ],
      "Resource": [
        "arn:aws:lambda:ap-southeast-1:508768431157:function:FightingGameMatchmaker",
        "arn:aws:lambda:ap-southeast-1:508768431157:function:FightingGameMatchmaker:*"
      ]
    }
  ]
}
