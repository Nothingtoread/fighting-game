{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadActiveMatchesStream",
      "Effect": "Allow",
      "Action": [
        "dynamodb:DescribeStream",
        "dynamodb:GetRecords",
        "dynamodb:GetShardIterator",
        "dynamodb:ListStreams"
      ],
      "Resource": "arn:aws:dynamodb:ap-southeast-1:508768431157:table/ActiveMatches/stream/*"
    },
    {
      "Sid": "WriteMatchAnalytics",
      "Effect": "Allow",
      "Action": ["dynamodb:PutItem"],
      "Resource": "arn:aws:dynamodb:ap-southeast-1:508768431157:table/MatchAnalytics"
    }
  ]
}
